{
  "name": "stencil-jp-watchface",
  "author": "Yoto",
  "version": "1.0.0",
  "keywords": ["pebble-app"],
  "private": true,
  "dependencies": {},
  "pebble": {
    "displayName": "Stencil JP",
    "uuid": "4f6f1046-9dd0-4d85-ab63-9da10681e567",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "emery"
    ],
    "watchapp": {
      "watchface": true
    },
    "capabilities": [
      "location"
    ],
    "messageKeys": [
      "TEMPERATURE",
      "CONDITIONS",
      "PRESSURE",
      "FC_TEMPERATURE",
      "FC_CONDITIONS",
      "FC_PRESSURE"
    ],
    "resources": {
      "media": [
        {
          "type": "font",
          "name": "FONT_KHAND_BOLD_100",
          "file": "fonts/Khand-Bold.ttf",
          "characterRegex": "[0-9]"
        },
        {
          "type": "font",
          "name": "FONT_KHAND_BOLD_54",
          "file": "fonts/Khand-Bold.ttf",
          "characterRegex": "[0-9A-Z]"
        }
      ]
    }
  }
}
